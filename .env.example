# Daraja M-PESA API Credentials (from Safaricom Developer Portal)
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here
DARAJA_SHORTCODE=your_till_or_paybill_number
DARAJA_PASSKEY=your_lipa_na_mpesa_passkey
DARAJA_INITIATOR_NAME=your_initiator_name
DARAJA_SECURITY_CREDENTIAL=your_encrypted_initiator_password

# Server Configuration
PORT=10000
NODE_ENV=production
HOST_URL=https://your-app.onrender.com

# Admin Authentication
ADMIN_USER=admin
ADMIN_PASS=SecurePassword123!

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Talksasa SMS API (for partner notifications)
TALKSASA_API_KEY=your_talksasa_api_key
TALKSASA_SENDER=JAirtimes

# Session Security
SESSION_SECRET=generate_a_strong_random_secret_here_at_least_32_chars
